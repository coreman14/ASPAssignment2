@model WebApplication2.Models.Borrowing

@{
    Layout = "_Layout";
    ViewData["Title"] = "Borrowing Details";
}

<h1 class="h3 mb-3">Borrowing Details</h1>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Borrowing</dt>
            <dd class="col-sm-9">@Model.ID</dd>

            <dt class="col-sm-3">BookId</dt>
            <dd class="col-sm-9"><a asp-controller="Book" asp-action="Book" asp-route-id="@Model.BookId" class="btn btn-sm btn-outline-secondary">@Model.BookId</a></dd>

            <dt class="col-sm-3">ReaderId</dt>
            <dd class="col-sm-9"><a asp-controller="Reader" asp-action="Reader" asp-route-id="@Model.ReaderId" class="btn btn-sm btn-outline-secondary">@Model.ReaderId</a></dd>

            <dt class="col-sm-3">Borrowed Date</dt>
            <dd class="col-sm-9">@Model.BorrowedDate</dd>

            <dt class="col-sm-3">Days to Borrow</dt>
            <dd class="col-sm-9">@Model.DaysToBorrow</dd>

            <dt class="col-sm-3">Return Date</dt>
            <dd class="col-sm-9">@(@Model.IsReturned ? @Model.ReturnedDate : "Not Returned")</dd>

        </dl>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Update" asp-route-id="@Model.ID" class="btn btn-primary">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.ID" class="btn btn-danger">Delete</a>
    <a class="btn btn-outline-secondary" href="javascript:history.back()">Go Back</a>
</div>
