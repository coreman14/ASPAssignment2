@model IEnumerable<WebApplication2.Models.Reader>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Readers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Readers</h1>
    <a asp-action="Create" class="btn btn-primary">Add New Reader</a>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No Readers found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reader in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="Reader" asp-route-id="@reader.ID">@reader.Name</a>
                        </td>
                        <td>@reader.Email</td>
                        <td class="text-end">
                            <a asp-action="Reader" asp-route-id="@reader.ID" class="btn btn-sm btn-outline-secondary">View</a>
                            <a asp-action="Update" asp-route-id="@reader.ID" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@reader.ID" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
