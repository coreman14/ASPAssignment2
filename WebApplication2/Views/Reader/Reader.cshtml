@model WebApplication2.Models.Reader

@{
    Layout = "_Layout";
    ViewData["Title"] = "Reader Details";
}

<h1 class="h3 mb-3">Reader Details</h1>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>
        </dl>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Update" asp-route-id="@Model.ID" class="btn btn-primary">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.ID" class="btn btn-danger">Delete</a>
    <a class="btn btn-outline-secondary" href="javascript:history.back()">Go Back</a>
</div>
