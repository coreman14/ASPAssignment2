@model IEnumerable<WebApplication2.Models.Reader>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Readers search";
    string? searchVal = @Context.Request.Query["searchstring"].ToString();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">@((ViewBag.results != null) ? ViewBag.results : "Readers")</h1>
</div>


<form method="get" class="mt-3">
    <div class="input-group">
        <input type="text" name="searchstring" class="form-control" placeholder="Search readers..." id="searchInput" 
        value="@searchVal">
        <button class="btn btn-primary" type="submit" id="searchBtn" disabled>Search</button>
    </div>
</form>
<script>
    document.getElementById('searchInput').addEventListener('input', function() {
        document.getElementById('searchBtn').disabled = !this.value.trim();
    });
</script>
@if (!Context.Request.Query.ContainsKey("searchstring")){}

else if (Model == null || !Model.Any()){
    <div class="alert alert-info">No Readers found found for search @searchVal.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reader in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="Reader" asp-route-id="@reader.ID">@reader.Name</a>
                        </td>
                        <td>@reader.Email</td>
                        <td class="text-end">
                            <a asp-action="Reader" asp-route-id="@reader.ID" class="btn btn-sm btn-outline-secondary">View</a>
                            <a asp-action="Update" asp-route-id="@reader.ID" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@reader.ID" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
