@{
    Layout = "_Layout";
	ViewData["Title"] = "Not Found";
	var missingType = ViewBag.missType as string ?? "Item";
}

<div class="alert alert-warning" role="alert">
	<h1 class="h4 mb-2">@missingType not found</h1>
	<p class="mb-0">The requested @missingType.ToLower() could not be found.</p>
</div>

<a class="btn btn-outline-secondary" href="javascript:history.back()">Go Back</a>
